# App
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-secret

# Single-domain API (frontend + backend on same URL)
NEXT_PUBLIC_API_BASE_URL=/api/backend

# Database
MONGODB_URI=mongodb://localhost:27017/rohan-rice

# JWT
JWT_SECRET=replace-with-random-jwt-secret
JWT_EXPIRE=7d

# OTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-app-password
SMTP_FROM=Rohan Rice <no-reply@rohanrice.com>

# OTP / SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional search indexing
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
ALGOLIA_INDEX_NAME=rohan_rice_products
